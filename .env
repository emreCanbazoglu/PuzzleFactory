# PuzzeFactory environment configuration
# Loaded manually by scripts via os.getenv — not auto-sourced

# ── Cloud LLM provider (used by reasoning roles) ──────────────────────────────
# Supported values: openai | ollama | claude | codex | mock
#   openai  — HTTP to OpenAI chat/completions API  (requires OPENAI_API_KEY)
#   ollama  — HTTP to local Ollama server           (requires Ollama running)
#   claude  — Claude Code CLI  `claude -p …`        (no API key; requires `claude` in PATH)
#   codex   — OpenAI Codex CLI `codex exec …`       (requires `codex` in PATH + Codex session)
#   mock    — deterministic template fill, no LLM   (safe default for dry runs)
PF_CLOUD_PROVIDER=mock
PF_CLOUD_MODEL=gpt-4o-mini

# ── Local LLM provider (used by builder/lighter roles) ────────────────────────
PF_LOCAL_PROVIDER=mock
PF_LOCAL_MODEL=qwen3:14b

# ── OpenAI (when PF_CLOUD_PROVIDER=openai) ────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Ollama (when using ollama for cloud or local) ─────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/api

# ── CLI provider settings (when PF_CLOUD_PROVIDER=claude or codex) ────────────
# CLAUDE_CLI_PATH=claude
# PF_CLAUDE_CLI_TIMEOUT_SECONDS=120
# CODEX_CLI_PATH=codex
# PF_CODEX_CLI_MODEL=gpt-5.3-codex
# PF_CODEX_CLI_TIMEOUT_SECONDS=120

# ── Safety ────────────────────────────────────────────────────────────────────
# Fall back to mock template fill instead of aborting when a provider fails.
# Mirrors run_config.json "execution.allow_mock_fallback".
PF_ALLOW_MOCK_FALLBACK=true
