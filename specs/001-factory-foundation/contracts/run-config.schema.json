{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://puzzlefusionfactory.local/contracts/run-config.schema.json",
  "title": "RunConfig",
  "type": "object",
  "additionalProperties": false,
  "required": ["wave_id", "cells", "routing", "decision_policy", "human_feedback"],
  "properties": {
    "wave_id": {"type": "string", "minLength": 1},
    "cells": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["cell_id", "discovery_domain", "prototype_domain", "concept_count"],
        "properties": {
          "cell_id": {"type": "string", "minLength": 1},
          "discovery_domain": {"type": "string", "minLength": 1},
          "prototype_domain": {"type": "string", "minLength": 1},
          "concept_count": {"type": "integer", "minimum": 1}
        }
      }
    },
    "routing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cloud_roles", "local_roles"],
      "properties": {
        "cloud_roles": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "local_roles": {"type": "array", "items": {"type": "string", "minLength": 1}}
      }
    },
    "decision_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["weights", "thresholds", "hard_gates"],
      "properties": {
        "weights": {
          "type": "object",
          "additionalProperties": false,
          "required": ["clarity", "depth", "level_scalability", "production_feasibility", "retention_potential", "novelty"],
          "properties": {
            "clarity": {"type": "number", "minimum": 0, "maximum": 1},
            "depth": {"type": "number", "minimum": 0, "maximum": 1},
            "level_scalability": {"type": "number", "minimum": 0, "maximum": 1},
            "production_feasibility": {"type": "number", "minimum": 0, "maximum": 1},
            "retention_potential": {"type": "number", "minimum": 0, "maximum": 1},
            "novelty": {"type": "number", "minimum": 0, "maximum": 1}
          }
        },
        "thresholds": {
          "type": "object",
          "additionalProperties": false,
          "required": ["expand_min", "iterate_min", "kill_max"],
          "properties": {
            "expand_min": {"type": "number", "minimum": 0, "maximum": 100},
            "iterate_min": {"type": "number", "minimum": 0, "maximum": 100},
            "kill_max": {"type": "number", "minimum": 0, "maximum": 100}
          }
        },
        "hard_gates": {
          "type": "object",
          "additionalProperties": false,
          "required": ["playable_required", "min_clarity"],
          "properties": {
            "playable_required": {"type": "boolean"},
            "min_clarity": {"type": "number", "minimum": 0, "maximum": 5}
          }
        }
      }
    },
    "human_feedback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "mode", "timeout_hours", "override_scope"],
      "properties": {
        "enabled": {"type": "boolean"},
        "mode": {"type": "string", "enum": ["advisory_window", "hard_approval", "off"]},
        "timeout_hours": {"type": "integer", "minimum": 0},
        "override_scope": {"type": "string", "minLength": 1}
      }
    }
  }
}
